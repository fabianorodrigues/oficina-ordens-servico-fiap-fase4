{
  "version": 1,
  "application": {
    "name": "oficina-ordens-servico",
    "environment": "Production",
    "containerPort": 8080
  },
  "aws": {
    "clusterNameParameter": "/oficina/infra/cluster/name",
    "ecrRepositoryParameter": "/oficina/infra/ecr/ordens",
    "regionFromWorkflow": true
  },
  "ecs": {
    "serviceName": "oficina-ordens-servico",
    "containerName": "oficina-ordens-servico",
    "migrationContainerName": "oficina-ordens-servico-migration",
    "desiredCount": 1,
    "launchType": "FARGATE",
    "targetGroupArnParameter": "/oficina/infra/ecs/ordens/target-group-arn",
    "logGroupNameParameter": "/oficina/infra/ecs/ordens/log-group-name",
    "taskSecurityGroupParameter": "/oficina/infra/ecs/task-security-group-id",
    "privateSubnet1Parameter": "/oficina/infra/subnets/private/1",
    "privateSubnet2Parameter": "/oficina/infra/subnets/private/2"
  },
  "secrets": {
    "runtimeDatabase": "/oficina/ordens/runtime-db",
    "migrationDatabase": "/oficina/ordens/migration-db"
  },
  "queues": {
    "commandsUrlParameter": "/oficina/infra/sqs/estoque-comandos/url",
    "commandsArnParameter": "/oficina/infra/sqs/estoque-comandos/arn",
    "commandsDlqUrlParameter": "/oficina/infra/sqs/estoque-comandos-dlq/url",
    "commandsDlqArnParameter": "/oficina/infra/sqs/estoque-comandos-dlq/arn",
    "eventsUrlParameter": "/oficina/infra/sqs/ordens-eventos/url",
    "eventsArnParameter": "/oficina/infra/sqs/ordens-eventos/arn",
    "eventsDlqUrlParameter": "/oficina/infra/sqs/ordens-eventos-dlq/url",
    "eventsDlqArnParameter": "/oficina/infra/sqs/ordens-eventos-dlq/arn",
    "consumerConcurrency": 1,
    "maxMessagesPerReceive": 1,
    "waitTimeSeconds": 20,
    "visibilityTimeoutSeconds": 60
  },
  "services": {
    "cadastroBaseUrlParameter": "/oficina/infra/alb/dns-name",
    "estoqueBaseUrlParameter": "/oficina/infra/alb/dns-name"
  },
  "payments": {
    "useMock": true,
    "mockBehavior": "Approved",
    "externalApiEnabled": false,
    "externalWebhookEnabled": false,
    "contractStatus": "Pending",
    "baseUrl": null,
    "submitPath": null,
    "timeoutSeconds": 5,
    "maxRetryAttempts": 2,
    "webhookPath": "/api/webhooks/payments",
    "maxWebhookBodyBytes": 65536
  },
  "health": {
    "path": "/health",
    "readinessPath": "/ready",
    "initialDelaySeconds": 10,
    "periodSeconds": 10,
    "timeoutSeconds": 3,
    "failureThreshold": 6
  },
  "deployment": {
    "progressDeadlineSeconds": 600,
    "terminationGracePeriodSeconds": 30
  }
}
